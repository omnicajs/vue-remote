{
  "name": "@omnicajs/vue-remote",
  "type": "module",
  "description": "Proxy renderer for Vue.js based on @remote-ui",
  "license": "MIT",
  "version": "0.2.22",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.cjs",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "require": "./dist/host.cjs",
      "import": "./dist/host.mjs",
      "default": "./dist/host.mjs"
    },
    "./remote": {
      "types": "./dist/remote.d.ts",
      "require": "./dist/remote.cjs",
      "import": "./dist/remote.mjs",
      "default": "./dist/remote.mjs"
    },
    "./tooling": {
      "types": "./dist/tooling.d.ts",
      "require": "./tooling.cjs",
      "import": "./tooling.mjs",
      "default": "./tooling.mjs"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "require": "./dist/vite-plugin.cjs",
      "import": "./dist/vite-plugin.mjs",
      "default": "./dist/vite-plugin.mjs"
    },
    "./webpack-loader": {
      "types": "./dist/webpack-loader.d.ts",
      "require": "./dist/webpack-loader.cjs",
      "import": "./dist/webpack-loader.mjs",
      "default": "./dist/webpack-loader.mjs"
    }
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "host": [
        "./dist/host.d.ts"
      ],
      "remote": [
        "./dist/remote.d.ts"
      ],
      "tooling": [
        "./dist/tooling.d.ts"
      ],
      "vite-plugin": [
        "./dist/vite-plugin.d.ts"
      ],
      "webpack-loader": [
        "./dist/webpack-loader.d.ts"
      ]
    }
  },
  "web-types": "./web-types.json",
  "scripts": {
    "build": "vite build",
    "coverage:clean": "rm -rf coverage && mkdir -p coverage",
    "coverage:merge": "rm -rf coverage/.nyc_output && node scripts/coverage-merge.mjs && nyc --nycrc-path .nycrc.json report && node scripts/coverage-summary.mjs",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "docs:prepare": "node ./scripts/docs-prepare.mjs",
    "docs:build": "yarn docs:prepare && astro build && node ./scripts/docs-relativize-links.mjs",
    "docs:dev": "yarn docs:prepare && astro dev",
    "docs:preview": "yarn docs:prepare && astro preview",
    "docs:typecheck": "yarn docs:prepare && astro check --tsconfig ./tsconfig.web.json --minimumSeverity error",
    "lint": "eslint .",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "test": "yarn typecheck && vitest run",
    "test:coverage": "yarn typecheck && vitest run --coverage",
    "test:dts": "tsc -p tsconfig.type-tests.json --noEmit",
    "test:tooling": "ts-node --esm tests/tooling/run-vue-tsc.mts",
    "test:e2e": "vitest run --config vitest.playwright.ts",
    "test:e2e:coverage": "vitest run --config vitest.playwright.ts --coverage",
    "test:all:coverage": "yarn coverage:clean && yarn test:coverage && yarn test:e2e:coverage && yarn coverage:merge",
    "typecheck": "tsc -p tsconfig.json --noEmit && yarn docs:typecheck"
  },
  "dependencies": {
    "@remote-ui/rpc": "^1.4.5"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/starlight": "^0.37.6",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/browser-playwright": "4.0.15",
    "@vitest/coverage-v8": "4.0.15",
    "@vue/compiler-sfc": "^3.5.25",
    "@vue/language-server": "^3.1.7",
    "astro": "^5.18.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "jsdom": "^27.3.0",
    "nyc": "^17.1.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.0.15",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "types",
    "index.cjs",
    "index.d.ts",
    "index.mjs",
    "tooling.cjs",
    "tooling.mjs",
    "web-types.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vue",
    "Vue.js",
    "remote",
    "remote-ui",
    "extension",
    "extending",
    "embed",
    "embedding"
  ],
  "contributors": [
    "Zaitsev Kirill <zaytsev.cmath10@gmail.com>"
  ],
  "homepage": "https://omnicajs.github.io/vue-remote/",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnicajs/vue-remote.git"
  },
  "packageManager": "yarn@4.13.0"
}
