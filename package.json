{
  "name": "@omnicajs/vue-remote",
  "type": "module",
  "description": "Proxy renderer for Vue.js based on @remote-ui",
  "license": "MIT",
  "version": "0.2.14",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.cjs",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "require": "./dist/host.cjs",
      "import": "./dist/host.mjs",
      "default": "./dist/host.mjs"
    },
    "./remote": {
      "types": "./dist/remote.d.ts",
      "require": "./dist/remote.cjs",
      "import": "./dist/remote.mjs",
      "default": "./dist/remote.mjs"
    }
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "host": [
        "./dist/host.d.ts"
      ],
      "remote": [
        "./dist/remote.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "coverage:clean": "rm -rf coverage && mkdir -p coverage",
    "coverage:merge": "rm -rf coverage/.nyc_output && mkdir -p coverage/.nyc_output && cp coverage/vitest/coverage-final.json coverage/.nyc_output/vitest.json && cp coverage/playwright/coverage-final.json coverage/.nyc_output/playwright.json && nyc --nycrc-path .nycrc.json merge coverage/.nyc_output coverage/coverage-final.json && nyc --nycrc-path .nycrc.json report && node scripts/coverage-summary.mjs",
    "coverage:summary": "node scripts/coverage-summary.mjs",
    "docs:prepare": "mkdir -p var/.astro && if [ ! -L .astro ]; then rm -rf .astro && ln -s var/.astro .astro; fi",
    "docs:build": "yarn docs:prepare && astro build && node ./scripts/docs-relativize-links.mjs",
    "docs:dev": "yarn docs:prepare && astro dev",
    "docs:preview": "yarn docs:prepare && astro preview",
    "lint": "eslint .",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "test": "vitest run ./tests/unit ./tests/integration",
    "test:coverage": "vitest run --coverage ./tests/unit ./tests/integration",
    "test:e2e": "vitest run --config vitest.playwright.ts",
    "test:e2e:coverage": "vitest run --config vitest.playwright.ts --coverage",
    "test:all:coverage": "yarn coverage:clean && yarn test:coverage && yarn test:e2e:coverage && yarn coverage:merge",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remote-ui/rpc": "^1.4.5"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/browser-playwright": "4.0.15",
    "@vitest/coverage-v8": "4.0.15",
    "@vue/compiler-sfc": "^3.5.25",
    "@vue/language-server": "^3.1.7",
    "astro": "^5.18.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "jsdom": "^27.3.0",
    "nyc": "^17.1.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vite-svg-loader": "^5.1.1",
    "vitest": "^4.0.15",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "types",
    "index.cjs",
    "index.d.ts",
    "index.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vue",
    "Vue.js",
    "remote",
    "remote-ui",
    "extension",
    "extending",
    "embed",
    "embedding"
  ],
  "contributors": [
    "Zaitsev Kirill <zaytsev.cmath10@gmail.com>"
  ],
  "homepage": "https://omnicajs.github.io/vue-remote/",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnicajs/vue-remote.git"
  },
  "packageManager": "yarn@4.13.0"
}
