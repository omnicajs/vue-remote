{
  "name": "@omnicajs/vue-remote",
  "type": "module",
  "description": "Proxy renderer for Vue.js based on @remote-ui",
  "license": "MIT",
  "version": "0.2.14-alpha.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.cjs",
      "import": "./index.mjs",
      "default": "./index.mjs"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "require": "./dist/host.cjs",
      "import": "./dist/host.mjs",
      "default": "./dist/host.mjs"
    },
    "./remote": {
      "types": "./dist/remote.d.ts",
      "require": "./dist/remote.cjs",
      "import": "./dist/remote.mjs",
      "default": "./dist/remote.mjs"
    }
  },
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "host": [
        "./dist/host.d.ts"
      ],
      "remote": [
        "./dist/remote.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "docs:prepare": "mkdir -p var/.astro && if [ ! -L .astro ]; then rm -rf .astro && ln -s var/.astro .astro; fi",
    "docs:build": "yarn docs:prepare && astro build && node ./scripts/docs-relativize-links.mjs",
    "docs:dev": "yarn docs:prepare && astro dev",
    "docs:preview": "yarn docs:prepare && astro preview",
    "e2e:build": "node tests/e2e/vite.build.mjs",
    "e2e:serve": "node ./tests/e2e/server.mjs",
    "e2e:test": "npx playwright test",
    "test": "vitest run ./tests/unit ./tests/integration",
    "test:coverage": "vitest run --coverage ./tests/unit ./tests/integration",
    "test:watch": "vitest ./tests/unit ./tests/integration",
    "lint": "eslint .",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@remote-ui/rpc": "^1.4.5"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.37.6",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.0.15",
    "@vue/compiler-sfc": "^3.5.25",
    "@vue/language-server": "^3.1.7",
    "astro": "^5.18.0",
    "cors": "^2.8.5",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "express": "^4.22.1",
    "globals": "^17.3.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "v8-to-istanbul": "^9.3.0",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "index.cjs",
    "index.d.ts",
    "index.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vue",
    "Vue.js",
    "remote",
    "remote-ui",
    "extension",
    "extending",
    "embed",
    "embedding"
  ],
  "contributors": [
    "Zaitsev Kirill <zaytsev.cmath10@gmail.com>"
  ],
  "homepage": "https://github.com/omnicajs/vue-remote",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnicajs/vue-remote.git"
  }
}
